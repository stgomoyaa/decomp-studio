{
  "name": "decomp-studio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "dist:desktop": "pnpm build && pnpm --filter @decomp-studio/desktop dist",
    "dist:desktop:dir": "pnpm build && pnpm --filter @decomp-studio/desktop dist:dir",
    "dev:desktop": "pnpm --filter @decomp-studio/desktop dev",
    "dev:server": "pnpm --filter @decomp-studio/server dev",
    "dev:web": "pnpm --filter @decomp-studio/web dev",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "typecheck": "tsc -b packages/* apps/*"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.0.14"
  }
}
